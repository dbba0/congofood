{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@wapi/types": [
        "../../packages/types/src"
      ],
      "@wapi/ui": [
        "../../packages/ui/src"
      ],
      "@wapi/api-client": [
        "../../packages/api-client/src"
      ],
      "@/*": [
        "./*"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.d.ts",
    "expo-env.d.ts",
    ".expo/types/**/*.ts"
  ]
}
