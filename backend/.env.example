# Serveur
PORT=3000
NODE_ENV=development

# Base de données MongoDB Atlas
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/congofood?retryWrites=true&w=majority

# JWT — utiliser des secrets longs et aléatoires en production
JWT_SECRET=change_me_in_production_at_least_64_chars_long
JWT_REFRESH_SECRET=change_me_refresh_in_production_at_least_64_chars_long
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# CinetPay — paiement Mobile Money (Airtel, Orange, M-Pesa)
CINETPAY_API_KEY=your_cinetpay_api_key
CINETPAY_SITE_ID=your_cinetpay_site_id
CINETPAY_NOTIFY_URL=https://api.congofood.cd/payments/webhook/cinetpay

# Africa's Talking — SMS OTP
# username=sandbox en dev (pas de vrais SMS, dev_code retourné dans la réponse)
# username=congofood en prod (compte vérifié Africa's Talking)
AFRICAS_TALKING_API_KEY=votre_cle_africa_talking
AFRICAS_TALKING_USERNAME=sandbox

# Firebase Cloud Messaging — notifications push
FCM_SERVER_KEY=your_fcm_server_key

# Cloudinary — stockage des images (logos, photos produits...)
CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name

# Redis — cache OTP (local en dev, Upstash en prod)
# Upstash TLS : rediss://username:password@hostname:port
REDIS_URL=redis://localhost:6379

# CORS — origines autorisées
CLIENT_URL=http://localhost:8081
ADMIN_URL=http://localhost:3001
