# Serveur
PORT=3000
NODE_ENV=development

# MongoDB Atlas
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/congofood?retryWrites=true&w=majority

# JWT — utiliser des secrets longs et aléatoires en production (min 64 chars)
JWT_SECRET=changez_ce_secret_en_production
JWT_REFRESH_SECRET=autre_secret_different
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# Redis (Upstash en prod — rediss://username:password@hostname:port)
REDIS_URL=redis://localhost:6379

# Africa's Talking — SMS OTP
# AFRICAS_TALKING_USERNAME=sandbox en dev (pas de vrais SMS)
# AFRICAS_TALKING_USERNAME=congofood en prod (compte vérifié)
AFRICAS_TALKING_API_KEY=votre_cle
AFRICAS_TALKING_USERNAME=sandbox

# CinetPay (paiement Mobile Money)
CINETPAY_API_KEY=
CINETPAY_SITE_ID=

# Frontend
CLIENT_URL=http://localhost:8081
ADMIN_URL=http://localhost:3001

# Firebase Cloud Messaging — notifications push (optionnel phase 1)
FCM_SERVER_KEY=

# Cloudinary — images (optionnel phase 1)
CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name
